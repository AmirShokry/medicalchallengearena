NUXT_BASE_URL="VALID_URL" # Replace with the actual base URL of your application
NUXT_AUTH_SECRET="LONG_RANDOM_STRING" # Replace with a secure random string
NUXT_AUTH_ORIGIN="BASE_URL/api/auth" #On production, this should be the URL of the website example https://example.com/api/auth
NITRO_PORT=ANY_PORT_NUMBER # Replace with the port number you want to use
PORT=ANY_PORT_NUMBER # Replace with the port number you want to use
STRIPE_PUBLISHABLE_KEY= "OBTAIN_FROM_STRIPE"
STRIPE_SECRET_KEY= "OBTAIN_FROM_STRIPE"
STRIPE_WEBHOOK_SECRET_KEY= "OBTAIN_FROM_STRIPE" # Replace with your Stripe webhook secret key

# Oracle Cloud Object Storage (used for user avatar uploads)
OCI_TENANCY_OCID="ocid1.tenancy.oc1..xxxxx"
OCI_USER_OCID="ocid1.user.oc1..xxxxx"
OCI_FINGERPRINT="aa:bb:cc:dd:ee:ff:..."
# Either the PEM contents (escape newlines as \n) OR an absolute path to a .pem file
OCI_PRIVATE_KEY="/absolute/path/to/oci_api_key.pem"
OCI_PRIVATE_KEY_PASSPHRASE="" # leave empty if your key has no passphrase
OCI_REGION="me-jeddah-1"      # the region your bucket lives in
OCI_NAMESPACE="your-tenancy-object-storage-namespace"
OCI_BUCKET_NAME="bucket-20260308-1833"