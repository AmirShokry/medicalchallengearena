IMAGE_API_KEY="OBTAIN_FROM_IMAGE_HIPPO"
NUXT_AUTH_SECRET="LONG_RANDOM_STRING" # Replace with a secure random string
NUXT_AUTH_ORIGIN="BASE_URL/api/auth" #On production, this should be the URL of the website example https://example.com/api/auth
NITRO_PORT= ANY_PORT_NUMBER
PORT= ANY_PORT_NUMBER # Same as above

# ── MCP connector (Claude.ai custom connector) ──
# Capability-URL secret. The connector endpoint is POST /mcp/<MCP_SECRET>.
# Generate a strong value: `openssl rand -hex 32` (or `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
# Keep this URL private — anyone with it can append cases.
MCP_SECRET="GENERATE_A_LONG_RANDOM_SECRET"
# Optional: comma-separated Host allowlist for DNS-rebinding hardening. Example: dashboard.example.com
MCP_ALLOWED_HOSTS=""